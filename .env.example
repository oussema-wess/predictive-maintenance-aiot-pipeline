# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_ORG=aiot-org
INFLUXDB_BUCKET_SENSORS=sensors
INFLUXDB_BUCKET_PREDICTIONS=predictions
INFLUXDB_BUCKET_ALERTS=alerts
INFLUXDB_BUCKET_MODEL_HEALTH=model_health

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SENSORS=sensor-data
KAFKA_TOPIC_PREDICTIONS=predictions
KAFKA_TOPIC_DRIFT=drift-alerts

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=factory/machines

# API
API_SECRET_KEY=change-this-secret-key
API_ALGORITHM=HS256
API_TOKEN_EXPIRE_MINUTES=60

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
